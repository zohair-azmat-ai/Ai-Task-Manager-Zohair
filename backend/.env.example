# ─── OpenAI (optional) ───────────────────────────────────────────────────────
# App works with rule-based fallback if not set
OPENAI_API_KEY=sk-your-key-here

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=change-this-to-a-long-random-string

# ─── Database ─────────────────────────────────────────────────────────────────
# Default is SQLite. Swap to PostgreSQL by changing this URL.
DATABASE_URL=sqlite:///./tasks.db

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your deployed Vercel frontend URL (comma-separated for multiple origins)
# Use "*" to allow all origins (acceptable for a portfolio/demo project)
FRONTEND_URL=https://your-app.vercel.app
